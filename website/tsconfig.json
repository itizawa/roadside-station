{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "rootDirs": [".", "./.react-router/types"],
    "noEmit": true
  },
  "include": [
    "app/**/*",
    "scripts/**/*",
    "react-router.config.ts",
    "vite.config.ts",
    ".react-router/types/**/*"
  ]
}
